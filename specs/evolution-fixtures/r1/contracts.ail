record CreateJobRequest identity "job.create-request.v1" {
  job_id identity "job-id": Text;
  task identity "task": Text;
  payload identity "payload": Bytes;
}

record Job identity "job.stored.v1" {
  job_id identity "job-id": Text;
  task identity "task": Text;
  payload identity "payload": Bytes;
}

record CreatedV1 identity "job.created.v1" {
  job identity "job": Job;
}

record ValidationIssue identity "job.validation-issue.v1" {
  field identity "field": ValidationField;
  reason identity "reason": ValidationReason;
}

record IssueNode identity "job.validation-issue-node.v1" {
  issue identity "issue": ValidationIssue;
  rest identity "rest": ValidationIssues;
}

variant ValidationField identity "job.validation-field.v1" {
  JobId identity "job-id";
  Task identity "task";
  Payload identity "payload";
}

variant ValidationReason identity "job.validation-reason.v1" {
  Missing identity "missing";
  InvalidFormat identity "invalid-format";
  TooLong identity "too-long";
  ControlCharacter identity "control-character";
  PayloadTooLarge identity "payload-too-large";
}

variant ValidationIssues identity "job.validation-issues.v1" {
  Empty identity "empty";
  More identity "more"(IssueNode);
}

variant InsertOutcome identity "job.insert-outcome.v1" {
  Inserted identity "inserted";
  Duplicate identity "duplicate";
  UnavailableBeforeCommit identity "unavailable-before-commit";
}

variant CreateJobResult identity "job.create-result.v1" {
  Created identity "created"(Job);
  Invalid identity "invalid"(ValidationIssues);
  AlreadyExists identity "already-exists"(Text);
  PersistenceUnavailable identity "persistence-unavailable";
}

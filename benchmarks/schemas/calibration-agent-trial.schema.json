{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ail.dev/schemas/calibration-agent-trial.schema.json",
  "title": "AIL M8 agent trial evidence",
  "type": "object",
  "required": [
    "trial_format",
    "trial_id",
    "schedule_id",
    "campaign_id",
    "configuration_id",
    "language",
    "task",
    "official",
    "terminal",
    "model",
    "inputs",
    "timing",
    "raw_events",
    "token_accounting",
    "activity",
    "permissions",
    "correctness",
    "artifacts"
  ],
  "properties": {
    "trial_format": {
      "const": 1
    },
    "trial_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "schedule_id": {
      "type": "string"
    },
    "campaign_id": {
      "type": "string"
    },
    "configuration_id": {
      "type": "string"
    },
    "language": {
      "enum": [
        "rust",
        "go",
        "python",
        "typescript"
      ]
    },
    "task": {
      "enum": [
        "UC-001",
        "UC-003"
      ]
    },
    "official": {
      "enum": [
        "yes",
        "no"
      ]
    },
    "terminal": {
      "type": "object",
      "required": [
        "class",
        "cause"
      ],
      "properties": {
        "class": {
          "enum": [
            "successful",
            "failed",
            "timed_out"
          ]
        },
        "cause": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "required": [
        "requested",
        "returned",
        "backend_snapshot",
        "service_tier",
        "reasoning_effort",
        "agent_version",
        "agent_sha256"
      ],
      "properties": {
        "requested": {
          "const": "gpt-5.6-sol"
        },
        "returned": {
          "type": "string"
        },
        "backend_snapshot": {
          "type": "string"
        },
        "service_tier": {
          "type": "string"
        },
        "reasoning_effort": {
          "const": "high"
        },
        "agent_version": {
          "const": "codex-cli 0.144.6"
        },
        "agent_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "required": [
        "task_start_tree_sha256",
        "task_sha256",
        "rendered_prompt_sha256",
        "private_package_sha256"
      ],
      "properties": {
        "task_start_tree_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "task_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "rendered_prompt_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "private_package_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "timing": {
      "type": "object",
      "required": [
        "started_monotonic_ns",
        "stopped_monotonic_ns",
        "elapsed_ns"
      ],
      "properties": {
        "started_monotonic_ns": {
          "type": "integer"
        },
        "stopped_monotonic_ns": {
          "type": "integer"
        },
        "elapsed_ns": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "raw_events": {
      "type": "object",
      "required": [
        "record_id",
        "path",
        "sha256",
        "count"
      ],
      "properties": {
        "record_id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "count": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "token_accounting": {
      "type": "object",
      "required": [
        "requests",
        "total_input_tokens",
        "cached_input_tokens",
        "categories"
      ],
      "properties": {
        "requests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "request_id",
              "preflight_input_tokens",
              "provider_input_tokens",
              "cached_input_tokens",
              "protocol_overhead_tokens",
              "categories"
            ],
            "properties": {
              "request_id": {
                "type": "string"
              },
              "preflight_input_tokens": {
                "type": "integer"
              },
              "provider_input_tokens": {
                "type": "integer"
              },
              "cached_input_tokens": {
                "type": "integer"
              },
              "protocol_overhead_tokens": {
                "type": "integer"
              },
              "categories": {
                "type": "object"
              }
            },
            "additionalProperties": false
          }
        },
        "total_input_tokens": {
          "type": "integer"
        },
        "cached_input_tokens": {
          "type": "integer"
        },
        "categories": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "activity": {
      "type": "object",
      "required": [
        "edits",
        "validation_attempts",
        "incomplete_validations",
        "repair_cycles"
      ],
      "properties": {
        "edits": {
          "type": "integer"
        },
        "validation_attempts": {
          "type": "integer"
        },
        "incomplete_validations": {
          "type": "integer"
        },
        "repair_cycles": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": [
        "profile_sha256",
        "violation_count",
        "protected_artifacts_match",
        "external_access_attempts"
      ],
      "properties": {
        "profile_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "violation_count": {
          "type": "integer"
        },
        "protected_artifacts_match": {
          "enum": [
            "yes",
            "no"
          ]
        },
        "external_access_attempts": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "correctness": {
      "type": "object",
      "required": [
        "revision_sha256",
        "public",
        "private",
        "seeded_consumers",
        "completion_evidence"
      ],
      "properties": {
        "revision_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "public": {
          "enum": [
            "passed",
            "failed",
            "not_run"
          ]
        },
        "private": {
          "enum": [
            "passed",
            "failed",
            "not_run"
          ]
        },
        "seeded_consumers": {
          "enum": [
            "passed",
            "failed",
            "not_run"
          ]
        },
        "completion_evidence": {
          "enum": [
            "passed",
            "failed",
            "not_run"
          ]
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "path",
          "sha256"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
